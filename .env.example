# ---------- Core ----------
DATABASE_URL=postgresql://kanban:kanban@localhost:5432/kanban
PORT=3001
ATTACHMENTS_DIR=./data/attachments
# Per-image upload cap for paste-to-attach (default: 5_000_000 = 5 MB).
ATTACHMENT_MAX_BYTES=5000000
COOKIE_SECRET=change-me-to-a-long-random-string

# Disable after initial registrations so only existing users can log in.
# (Default: true. Set to "false" once everyone is registered.)
OPEN_SIGNUP=true

# ---------- Telegram ----------
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Group chat ID (find via @userinfobot while the bot is in the group, or
# log a message at bot startup). Without this, the bot will ignore everything.
TELEGRAM_GROUP_ID=

# Public HTTPS URL the bot posts updates to. If unset the server falls back to
# long polling (fine for local dev).
#   Webhook path: /telegram/webhook/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=change-me-webhook

# ---------- AI ----------
# OpenRouter is the primary chat+vision provider (cheaper, model choice).
# OpenAI is required for voice transcription (Whisper) and acts as a chat/vision
# fallback if OpenRouter ever fails. You can set either, neither, or both.
#
# Without any key: voice -> "[voice note — transcription failed]", photos ->
# "[photo — needs review]", text skips the interactive propose/edit/save flow.

# Primary (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# Fallback + audio (OpenAI)
OPENAI_API_KEY=

# Optional: used as HTTP-Referer on OpenRouter requests (appears in their dashboard)
APP_URL=http://localhost:8010

# Knowledge — auto-fetch URL on save (default true)
KNOWLEDGE_AUTOFETCH=true
KNOWLEDGE_FETCH_TIMEOUT_MS=10000
KNOWLEDGE_BODY_MAX_CHARS=200000
# Knowledge — AI semantic search (requires OPENAI_API_KEY + pgvector extension)
KNOWLEDGE_EMBEDDINGS=false
